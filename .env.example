# ──────────────────────────────────────────────────────────────
#  MediGuide AI — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to git — it is in .gitignore.
# ──────────────────────────────────────────────────────────────

# ── MongoDB Atlas Connection String ───────────────────────────
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mediguide?retryWrites=true&w=majority

# ── Flask Secret Key ──────────────────────────────────────────
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Gemini (Google AI) API Key ─────────────────────────────────
# Get from: https://aistudio.google.com/apikey
# Leave blank to use rule-based responses only
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override model (default: gemini-2.0-flash-lite)
# GEMINI_MODEL=gemini-2.0-flash-lite

# ── Blood Bank Alert Contact ──────────────────────────────────
BLOOD_BANK_EMAIL=bloodbank@hospital.com
BLOOD_BANK_PHONE=+91-XXXXXXXXXX

# ── Gmail SMTP — Emergency Email Notifications ───────────────
# The email ABOVE (BLOOD_BANK_EMAIL) will receive emergency alerts.
# SMTP_EMAIL    = the Gmail account you send FROM (must have App Password enabled)
# SMTP_PASSWORD = Google App Password (16 chars, NOT your normal password)
#   How to get:
#     1. Go to https://myaccount.google.com/apppasswords
#     2. Enable 2-Step Verification first (if not already)
#     3. Create an App Password → copy the 16-char code → paste below
SMTP_EMAIL=
SMTP_PASSWORD=

# ── Flask Environment ─────────────────────────────────────────
# Use "development" locally, "production" on Render/cloud
FLASK_ENV=development

# ── Server Port (optional — defaults to 5000) ─────────────────
# PORT=5000
